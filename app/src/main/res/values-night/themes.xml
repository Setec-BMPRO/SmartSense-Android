<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmartSense" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary orange (lighter for dark theme) -->
        <item name="colorPrimary">#FF7043</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#832200</item>
        <item name="colorOnPrimaryContainer">#FFDBC9</item>

        <!-- Secondary -->
        <item name="colorSecondary">#E7BDB0</item>
        <item name="colorOnSecondary">#442A20</item>
        <item name="colorSecondaryContainer">#5D4035</item>
        <item name="colorOnSecondaryContainer">#FFDBC9</item>

        <!-- Tertiary amber -->
        <item name="colorTertiary">#D9C58D</item>
        <item name="colorOnTertiary">#3B2F05</item>
        <item name="colorTertiaryContainer">#534519</item>
        <item name="colorOnTertiaryContainer">#F6E1A7</item>

        <!-- Error -->
        <item name="colorError">#FFB4AB</item>
        <item name="colorOnError">#690005</item>

        <!-- Surface (clean neutral dark) -->
        <item name="colorSurface">#121212</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="colorSurfaceVariant">#2C2C2C</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>
        <item name="colorOutline">#757575</item>
        <item name="colorOutlineVariant">#383838</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/tab_bar_background</item>
        <item name="android:windowBackground">#121212</item>
        <item name="elevationOverlayEnabled">false</item>
    </style>
</resources>
