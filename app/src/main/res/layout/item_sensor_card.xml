<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginBottom="@dimen/spacing_sm"
    style="@style/Widget.SmartSense.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md">

        <!-- Tank image + level -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sensor_tank_container"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:strokeWidth="1.5dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <com.smartsense.app.ui.views.TankLevelMiniView
                    android:id="@+id/sensor_tank_mini"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/sensor_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textStyle="bold"
                tools:text="75%" />
        </LinearLayout>

        <!-- Sensor info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_md">

            <!-- Name -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/sensor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                tools:text="Propane - BBQ"/>



            <!-- Info row: battery, temp, signal -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <!-- Battery -->
                <ImageView
                    android:id="@+id/sensor_battery_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_battery_full"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@string/battery"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/sensor_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginStart="2dp"
                    tools:text="95%"/>

                <!-- Divider -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- Temperature -->
                <ImageView
                    android:id="@+id/sensor_temp_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:visibility="gone"
                    android:src="@drawable/ic_temp_warm"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@string/temperature"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/sensor_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginStart="2dp"
                    tools:text="22.5°C"/>

                <!-- Divider -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · " android:visibility="gone"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- Signal -->
                <ImageView
                    android:id="@+id/sensor_signal_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_signal_good"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@string/signal_strength"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/sensor_signal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginStart="2dp"
                    tools:text="Good"/>
            </LinearLayout>

            <!-- Last updated -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/sensor_last_updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="@dimen/spacing_xs"
                tools:text="Updated 5s ago"/>
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/sensor_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_sensor_type"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xs"
                android:textSize="10sp"

                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textAllCaps="true"
                android:textStyle="bold"
                tools:text="Standard"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
