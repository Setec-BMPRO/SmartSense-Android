<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.detail.SensorDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Back button and title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_sm">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_back"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                style="@style/Widget.Material3.Button.IconButton"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/sensor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:layout_marginStart="@dimen/spacing_sm"
                tools:text="Propane - BBQ"/>
        </LinearLayout>

        <!-- Large gauge -->
        <com.smartsense.app.ui.views.TankGaugeView
            android:id="@+id/detail_gauge"
            android:layout_width="@dimen/gauge_size_large"
            android:layout_height="@dimen/gauge_size_large"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            app:gaugeStrokeWidth="@dimen/gauge_stroke_width_large"/>

        <!-- Last updated -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/last_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="Updated 5s ago"/>

        <!-- Tank Level card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            app:cardCornerRadius="12dp"
            style="@style/Widget.Material3.CardView.Filled">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_tank"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/tank_level"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/tank_level"
                    android:textAppearance="?attr/textAppearanceTitleSmall"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/detail_level_height"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="182 mm"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Battery card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardCornerRadius="12dp"
            style="@style/Widget.Material3.CardView.Filled">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_battery"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/battery"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/battery"
                    android:textAppearance="?attr/textAppearanceTitleSmall"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/detail_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="95%"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Signal card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardCornerRadius="12dp"
            style="@style/Widget.Material3.CardView.Filled">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_signal"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/signal_strength"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/signal_strength"
                    android:textAppearance="?attr/textAppearanceTitleSmall"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/detail_signal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="Good (-45 dBm)"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Temperature card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardCornerRadius="12dp"
            style="@style/Widget.Material3.CardView.Filled">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_temperature"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/temperature"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/temperature"
                    android:textAppearance="?attr/textAppearanceTitleSmall"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/detail_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="22.5°C"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Read Quality card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardCornerRadius="12dp"
            style="@style/Widget.Material3.CardView.Filled">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_signal"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/read_quality"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/read_quality"
                    android:textAppearance="?attr/textAppearanceTitleSmall"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/detail_quality_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Good"
                    style="@style/Widget.Material3.Chip.Assist"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tank type card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardCornerRadius="12dp"
            style="@style/Widget.Material3.CardView.Filled">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_tank"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@string/tank_type"/>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/tank_type"
                    android:textAppearance="?attr/textAppearanceTitleSmall"/>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/detail_tank_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorPrimary"
                    tools:text="20 lb (BBQ)"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Unpair button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unpair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/remove_sensor"
            android:textColor="?attr/colorError"
            app:iconTint="?attr/colorError"
            app:strokeColor="?attr/colorError"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
